# Copy to .env.dev (same directory) — this file is gitignored.
# Kustomize secretGenerator reads .env.dev to create the hello-login-secrets Secret.
#
# Run: cp k8s/overlays/dev/.env.dev.example k8s/overlays/dev/.env.dev

# "mysql" resolves to the mysql Service defined in mysql.yaml.
# The password (devpass) matches the hardcoded MYSQL_PASSWORD in mysql.yaml.
DATABASE_URL=mysql+pymysql://hello:devpass@mysql:3306/hello_login

JWT_SECRET=change-me-use-a-long-random-string-at-least-32-chars

# Set to 1 to suppress email delivery in dev
MAIL_SUPPRESS_SEND=1
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-brevo-login@example.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_DEFAULT_SENDER=your-brevo-login@example.com

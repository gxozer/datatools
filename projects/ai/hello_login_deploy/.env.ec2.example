# Copy to .env.ec2 and fill in your values.
# Run: cp .env.ec2.example .env.ec2
# .env.ec2 is gitignored — never commit it.
#
# After `terraform apply` in infra/dev/`, get the EC2 public IP:
#   cd infra/dev && terraform output public_ip
# Then update FRONTEND_URL and CORS_ORIGINS below.
#
# `make dev-deploy` deploys this file to the EC2 as .env, which Docker Compose
# auto-loads for YAML variable interpolation (${IMAGE_TAG}) and backend container env vars.

# ── App ───────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=5001
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-chars

# Your domain pointing to the EC2 Elastic IP (e.g. dev.yourdomain.com)
# Add a DNS A record: DEV_DOMAIN -> `cd infra/dev && terraform output public_ip`
DEV_DOMAIN=dev.yourdomain.com
FRONTEND_URL=https://dev.yourdomain.com
CORS_ORIGINS=https://dev.yourdomain.com

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=15

# ── Database ──────────────────────────────────────────────────────────────────
# "mysql" resolves to the mysql Docker Compose service — do not change the hostname.
# The password (devpass) matches the hardcoded MYSQL_PASSWORD in docker-compose.ec2.yml.
DATABASE_URL=mysql+pymysql://hello:devpass@mysql:3306/hello_login

# ── Email ─────────────────────────────────────────────────────────────────────
# MAIL_SUPPRESS_SEND=1 skips actual email delivery — safe for dev.
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_SUPPRESS_SEND=1
MAIL_USERNAME=your-brevo-login@example.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_DEFAULT_SENDER=your-brevo-login@example.com

# ── Image tag (used by docker-compose.ec2.yml for ${IMAGE_TAG:-latest}) ───────
IMAGE_TAG=latest

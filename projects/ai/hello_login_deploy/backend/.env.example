FLASK_DEBUG=true
PORT=5001
JWT_SECRET=your-secret-key-here
FRONTEND_URL=http://localhost:5173

# Email — Brevo SMTP (https://app.brevo.com/settings/keys/smtp)
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-brevo-login-email@example.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_DEFAULT_SENDER=your-brevo-login-email@example.com

# Set to 1 to suppress email sending in development
# MAIL_SUPPRESS_SEND=1

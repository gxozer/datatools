<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        Set CF_LOG_LEVEL=DEBUG to see full request URLs, retry attempts, and
        throttle waits. Default is INFO (user-facing progress only).
    -->
    <root level="${CF_LOG_LEVEL:-INFO}">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
